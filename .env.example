# Скопируйте в .env и подставьте свои значения (.env уже в .gitignore, наружу не уйдёт).
# Формат простой: KEY=VALUE, # — комментарий, значения с пробелами — в кавычках.

# Способ подключения к устройству (mesh_logger.py): wifi | usb | ble
MESH_CONN_TYPE=wifi

# Язык интерфейса клиента (сообщения, ответы бота, описания настроек): ru | en.
# Лог-файлы языконезависимы — это только про то, что показывает mesh_chat.py.
# Оба процесса читают этот ключ при старте, так что после смены логгер нужно
# перезапустить.
MESH_LANG=ru

# Адрес устройства для WiFi-подключения (используется при MESH_CONN_TYPE=wifi)
MESH_HOST=meshtastic.local

# Путь к serial-порту для USB-подключения (MESH_CONN_TYPE=usb), например
# /dev/ttyUSB0 или /dev/cu.usbserial-0001 — оставьте пустым, чтобы logger
# сам нашёл единственное подключённое по USB устройство
MESH_USB_PORT=

# MAC/UUID адрес устройства для Bluetooth-подключения (MESH_CONN_TYPE=ble) —
# оставьте пустым, чтобы logger сам подключился, если рядом ровно одно
# Meshtastic-устройство по BLE
MESH_BLE_ADDRESS=

# Идентичность своей ноды — можно оставить пустыми: /who в mesh_chat.py сам
# заполнит эти три поля при первом запуске и будет обновлять их дальше
NODE_LONG_NAME=
NODE_SHORT_NAME=
NODE_ID=
